{
  "name": "@manovaspace/observability",
  "version": "0.1.0",
  "description": "Next.js instrumentation helpers for Sentry and optional OpenTelemetry",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "observability",
    "sentry",
    "nextjs",
    "instrumentation",
    "opentelemetry",
    "monitoring"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manovaspace/ts.git",
    "directory": "packages/observability"
  },
  "bugs": {
    "url": "https://github.com/manovaspace/ts/issues"
  },
  "homepage": "https://github.com/manovaspace/ts/tree/main/packages/observability#readme",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next/instrumentation.d.ts",
      "import": "./dist/next/instrumentation.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@sentry/nextjs": "catalog:",
    "next": "catalog:"
  },
  "peerDependenciesMeta": {
    "@sentry/nextjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@manovaspace/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
