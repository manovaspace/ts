{
  "name": "@manovaspace/pwa",
  "version": "1.0.2",
  "description": "Serwist and web app manifest helpers for Next.js progressive web apps",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/sw/default.js"
  ],
  "keywords": [
    "pwa",
    "serwist",
    "nextjs",
    "service-worker",
    "web-app-manifest",
    "offline",
    "progressive-web-app"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manovaspace/ts.git",
    "directory": "packages/pwa"
  },
  "bugs": {
    "url": "https://github.com/manovaspace/ts/issues"
  },
  "homepage": "https://manovaspace.github.io/ts/packages/pwa/",
  "scripts": {
    "prepublishOnly": "node ../../scripts/assert-publishable-deps.mjs",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "default": "./dist/next/index.js"
    },
    "./react": {
      "types": "./dist/react/serwist-shell.d.ts",
      "import": "./dist/react/serwist-shell.js",
      "default": "./dist/react/serwist-shell.js"
    },
    "./sw": {
      "types": "./dist/sw/default.d.ts",
      "import": "./dist/sw/default.js",
      "default": "./dist/sw/default.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "next": "^16.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@serwist/turbopack": "^9.5.11",
    "serwist": "^9.5.11"
  },
  "devDependencies": {
    "@manovaspace/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
