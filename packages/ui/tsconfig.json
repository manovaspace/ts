{
  "extends": "@manovaspace/tsconfig/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "components": ["./src"],
      "ui": ["./src/primitives"],
      "lib": ["./src/lib"],
      "hooks": ["./src/hooks"],
      "utils": ["./src/lib/utils.ts"]
    }
  },
  "include": ["src", "types"]
}
