{
  "name": "@manovaspace/ui",
  "version": "0.2.0",
  "description": "Radix and Tailwind component primitives with motion, icons, and token integration",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "keywords": ["react", "radix", "tailwind", "design-system", "components", "shadcn"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manovaspace/ts.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/manovaspace/ts/issues"
  },
  "homepage": "https://manovaspace.github.io/ts/packages/ui/",
  "scripts": {
    "prepublishOnly": "node ../../scripts/assert-publishable-deps.mjs",
    "build": "tsup && pnpm build:css",
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "dev": "pnpm build:css && tailwindcss -i ./src/styles.css -o ./dist/styles.css --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js"
    },
    "./icons/solid": {
      "types": "./dist/icons-solid.d.ts",
      "import": "./dist/icons-solid.js"
    },
    "./icons/brand": {
      "types": "./dist/icons-brand.d.ts",
      "import": "./dist/icons-brand.js"
    },
    "./motion": {
      "types": "./dist/motion/index.d.ts",
      "import": "./dist/motion/index.js"
    },
    "./loading": {
      "types": "./dist/loading/index.d.ts",
      "import": "./dist/loading/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./src/server/index.ts",
      "default": "./dist/server/index.js"
    }
  },
  "files": ["dist", "src/server", "components.json"],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "dependencies": {
    "@manovaspace/tokens": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react-icons": "^5.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@manovaspace/tsconfig": "workspace:*",
    "@tailwindcss/cli": "catalog:",
    "@testing-library/react": "^16.3.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "^26.1.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
